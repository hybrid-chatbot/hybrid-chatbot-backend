# ===========================================
# hybrid-chatbot-backend 환경 변수 설정
# ===========================================
# 이 파일을 복사하여 .env 파일을 만들고, 실제 값을 채워넣으세요.
# cp .env.example .env

# --- Spring 프로필 ---
# local: Kafka/Dialogflow 비활성화 (로컬 개발용)
# dev: 개발 환경
# test: 테스트 환경
SPRING_PROFILES_ACTIVE=local

# --- 서버 포트 ---
SERVER_PORT=8080

# --- AI 서버 (FastAPI) ---
AI_SERVER_URL=http://localhost:8000

# --- OpenAI ---
OPENAI_API_KEY=your-openai-api-key-here

# --- MongoDB Atlas ---
MONGODB_URI=mongodb+srv://dnxkdxkd7979_db_user:<db_password>@cluster0.d9mxxmq.mongodb.net/chatbot?retryWrites=true&w=majority&appName=Cluster0

# --- Redis ---
REDIS_HOST=localhost
REDIS_PORT=6379

# --- Dialogflow (선택사항) ---
# Dialogflow를 사용하려면 true로 변경하고 인증 정보를 설정하세요
DIALOGFLOW_ENABLED=false
DIALOGFLOW_PROJECT_ID=hybrid-chatbot
# DIALOGFLOW_CREDENTIALS={"type":"service_account",...}

# --- Naver Shopping API (선택사항) ---
# NAVER_SHOPPING_CLIENT_ID=your-naver-client-id
# NAVER_SHOPPING_CLIENT_SECRET=your-naver-client-secret
